# Required non-secret GitHub App settings
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY_PATH=/home/example/.config/workflowd/github-app.pem

# OpenCode must use the same username and password as opencode-server.service.
OPENCODE_SERVER_USERNAME=opencode
# Comma-separated GitHub usernames; leave empty to disable commands.
WORKFLOWD_COMMAND_USERS=example-user
# Safe default. Enable only when agent-owned pull requests are trusted to run
# repository verification commands on this host.
WORKFLOWD_FIX_WORK_ENABLED=false

# The systemd unit supplies these from LoadCredential. Do not also set the
# direct variables in the installed EnvironmentFile.
# GITHUB_WEBHOOK_SECRET_FILE=/run/credentials/.../github-webhook-secret
# OPENCODE_SERVER_PASSWORD_FILE=/run/credentials/.../opencode-server-password

# For local development without systemd, set exactly one source per secret.
# GITHUB_WEBHOOK_SECRET=replace-with-a-random-secret
# OPENCODE_SERVER_PASSWORD=replace-with-the-local-server-password
# GITHUB_WEBHOOK_SECRET_FILE=/absolute/path/to/webhook-secret
# OPENCODE_SERVER_PASSWORD_FILE=/absolute/path/to/opencode-password

# HTTP
# WORKFLOWD_HOST=127.0.0.1
# WORKFLOWD_PORT=8787
# WORKFLOWD_MAX_WEBHOOK_BYTES=1048576

# OpenCode
# OPENCODE_SERVER_URL=http://127.0.0.1:4096
# WORKFLOWD_MODEL=openai/gpt-5.6-sol
# WORKFLOWD_REVIEWER_AGENT=pr-reviewer
# WORKFLOWD_FIXER_AGENT=pr-fixer
# WORKFLOWD_OPENCODE_POLL_INTERVAL_MS=1000

# Storage and workspace
# WORKFLOWD_STATE_DIR=/home/example/.local/state/workflowd
# WORKFLOWD_CACHE_DIR=/home/example/.local/share/workflowd
# WORKFLOWD_DATABASE_PATH=/home/example/.local/state/workflowd/workflowd.db
# WORKFLOWD_REPOSITORY_ROOT=/home/example/.local/share/workflowd/repositories
# WORKFLOWD_WORKTREE_ROOT=/home/example/.local/share/workflowd/worktrees
# OPENCODE_WORKTREE_REGISTRY=/home/example/.local/share/opencode/worktree-jobs
# Colon-separated repository roots:
# WORKFLOWD_LOCAL_REPOSITORIES=/home/example/Documents/repos
# WORKFLOWD_MAX_DIFF_BYTES=2000000

# Worker policy
# WORKFLOWD_WORKER_CONCURRENCY=2
# WORKFLOWD_POLL_INTERVAL_MS=1000
# WORKFLOWD_JOB_TIMEOUT_MS=1800000
# WORKFLOWD_JOB_LEASE_MS=1860000
# WORKFLOWD_PUBLICATION_TIMEOUT_MS=60000
# WORKFLOWD_PUBLICATION_LEASE_MS=120000
# Comma-separated, non-empty branch prefixes:
# WORKFLOWD_AGENT_BRANCH_PREFIXES=opencode/,plan/
